@model NorthwindApp.Models.Supplier

@{
    ViewData["Title"] = "Detalle de Proveedor";
}

<h1>@Model.CompanyName</h1>
<p><strong>Contacto:</strong> @Model.ContactName — @Model.ContactTitle</p>
<p><strong>Ubicación:</strong> @Model.City, @Model.Country</p>

<h3>Productos de este proveedor</h3>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Producto</th>
            <th>Precio</th>
            <th>Stock</th>
        </tr>
    </thead>
    <tbody>
@foreach (var p in Model.Products) {
        <tr>
            <td>@p.ProductName</td>
            <td>@(p.UnitPrice?.ToString("C"))</td>
            <td>@p.UnitsInStock</td>
        </tr>
}
    </tbody>
</table>

<a asp-controller="Suppliers" asp-action="Index" class="btn btn-secondary">Volver</a>
