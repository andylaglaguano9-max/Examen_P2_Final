@model NorthwindApp.Models.Category

@{
    ViewData["Title"] = "Detalle de Categoría";
}

<h1>@Model.CategoryName</h1>
<p>@Model.Description</p>

<h3>Productos en esta categoría</h3>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Producto</th>
            <th>Precio</th>
            <th>Stock</th>
        </tr>
    </thead>
    <tbody>
@foreach (var p in Model.Products) {
        <tr>
            <td>@p.ProductName</td>
            <td>@(p.UnitPrice?.ToString("C"))</td>
            <td>@p.UnitsInStock</td>
        </tr>
}
    </tbody>
</table>

<a asp-controller="Categories" asp-action="Index" class="btn btn-secondary">Volver</a>
