@model IEnumerable<NorthwindApp.Models.Category>

@{
    ViewData["Title"] = "Categorías";
}

<h1>Categorías</h1>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.CategoryName</td>
            <td>@item.Description</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-info">Ver Productos</a>
            </td>
        </tr>
}
    </tbody>
</table>
