@model IEnumerable<NorthwindApp.Models.Product>

@{
    ViewData["Title"] = "Productos";
}

<h1>Productos</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo</a>
    <a asp-action="MasCaros" class="btn btn-info">Top 10 Más Caros</a>
    <a asp-action="BuscarPorNombre" class="btn btn-warning">Buscar por Nombre</a>
    <a asp-action="ProductosPorProveedor" class="btn btn-secondary">Por Proveedor</a>
    <a asp-action="ProductosPorCategoria" class="btn btn-success">Por Categoría (Join)</a>
    <a asp-action="ProductosProveedorEspecifico" class="btn btn-dark">Proveedor USA > $10</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.Category?.CategoryName</td>
            <td>@item.Supplier?.CompanyName</td>
            <td>@(item.UnitPrice?.ToString("C"))</td>
            <td>@item.UnitsInStock</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary">Editar</a>
                <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-info">Detalle</a>
                <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>
