@model NorthwindApp.Models.Product

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1>Eliminar Producto</h1>
<h3 class="text-danger">¿Estás seguro de eliminar este producto?</h3>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Producto</dt>
            <dd class="col-sm-8">@Model.ProductName</dd>

            <dt class="col-sm-4">Categoría</dt>
            <dd class="col-sm-8">@Model.Category?.CategoryName</dd>

            <dt class="col-sm-4">Proveedor</dt>
            <dd class="col-sm-8">@Model.Supplier?.CompanyName</dd>

            <dt class="col-sm-4">Precio</dt>
            <dd class="col-sm-8">@(Model.UnitPrice?.ToString("C"))</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="ProductId" />
    <input type="submit" value="Eliminar" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
