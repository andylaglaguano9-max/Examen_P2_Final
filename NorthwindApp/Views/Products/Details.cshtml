@model NorthwindApp.Models.Product

@{
    ViewData["Title"] = "Detalle del Producto";
}

<h1>Detalle del Producto</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.ProductName</h5>
        <dl class="row">
            <dt class="col-sm-4">Categoría</dt>
            <dd class="col-sm-8">@Model.Category?.CategoryName</dd>

            <dt class="col-sm-4">Proveedor</dt>
            <dd class="col-sm-8">@Model.Supplier?.CompanyName</dd>

            <dt class="col-sm-4">Cantidad por Unidad</dt>
            <dd class="col-sm-8">@Model.QuantityPerUnit</dd>

            <dt class="col-sm-4">Precio Unitario</dt>
            <dd class="col-sm-8">@(Model.UnitPrice?.ToString("C"))</dd>

            <dt class="col-sm-4">Unidades en Stock</dt>
            <dd class="col-sm-8">@Model.UnitsInStock</dd>

            <dt class="col-sm-4">Unidades en Orden</dt>
            <dd class="col-sm-8">@Model.UnitsOnOrder</dd>

            <dt class="col-sm-4">Descontinuado</dt>
            <dd class="col-sm-8">@(Model.Discontinued == 1 ? "Sí" : "No")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
</div>
